{
  "name": "cloudshell",
  "version": "1.0.0",
  "description": "Web-based terminal with Claude Code integration",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "cloudshell": "dist/server.js"
  },
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/darrinm/cloudshell.git" },
  "homepage": "https://github.com/darrinm/cloudshell",
  "bugs": "https://github.com/darrinm/cloudshell/issues",
  "keywords": ["terminal", "claude", "ai", "pty", "webgl", "shell"],
  "engines": { "node": ">=20" },
  "files": ["dist/", "web/dist/", "README.md", "LICENSE"],
  "scripts": {
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null; true",
    "build": "tsc",
    "build:web": "cd web && npm run build",
    "build:all": "npm run build && npm run build:web",
    "check-types": "tsc --noEmit && cd web && tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'web/src/**/*.{ts,tsx}'",
    "start": "node dist/server.js",
    "predev": "lsof -ti:4444 | xargs kill -9 2>/dev/null; true",
    "dev": "nodemon --watch src --ext ts --exec 'npm run build && node dist/server.js'"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.72",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-pty": "^1.1.0",
    "open": "^11.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "nodemon": "^3.1.14",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "vite": "^7.3.1"
  }
}
